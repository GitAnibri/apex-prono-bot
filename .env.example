# ============================================================
# APEX PRONOS AI — Variables d'environnement
# Copie ce fichier en .env et remplis les valeurs
# ============================================================

# --- Discord ---
DISCORD_TOKEN=ton_token_discord_ici
DISCORD_GUILD_ID=ton_guild_id_ici

# --- API Football (api-football.com) ---
API_FOOTBALL_KEY=ta_cle_api_football_ici
API_FOOTBALL_HOST=v3.football.api-sports.io

# --- Twitter/X ---
TWITTER_BEARER_TOKEN=ton_bearer_token_twitter_ici

# --- Configuration ---
BOT_PREFIX=!
DEBUG_MODE=False
CACHE_EXPIRY_SECONDS=3600
MONTE_CARLO_SIMULATIONS=10000
DATABASE_PATH=data/apex_pronos.db
